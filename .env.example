# API
EXPO_PUBLIC_API_URL=http://localhost:8080/api/v1

# Google OAuth — create credentials at https://console.cloud.google.com/
# Web client ID  → used by Expo Go via auth.expo.io proxy
#   Authorized redirect URI: https://auth.expo.io/@<your-expo-username>/<app-slug>
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=<web-client-id>.apps.googleusercontent.com
# Android client ID → used in preview/production EAS builds
#   Register SHA-1 from: eas credentials
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=<android-client-id>.apps.googleusercontent.com
# iOS client ID → used in preview/production EAS builds
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=<ios-client-id>.apps.googleusercontent.com
