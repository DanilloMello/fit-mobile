# API
EXPO_PUBLIC_API_URL=http://localhost:8080/api/v1

# Google OAuth — create credentials at https://console.cloud.google.com/
# Web client ID is used by Expo Go (add https://auth.expo.io/@<your-username>/connecthealth as authorized redirect URI)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=https://auth.expo.io/@<your-username>/connecthealth-dev
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
